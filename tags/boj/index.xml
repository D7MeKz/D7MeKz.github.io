&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1">&lt;/span> &lt;span class="k">if&lt;/span> &lt;span class="nx">dday&lt;/span>&lt;span class="p">.&lt;/span>&lt;span class="nx">Year&lt;/span>&lt;span class="o">-&lt;/span>&lt;span class="nx">today&lt;/span>&lt;span class="p">.&lt;/span>&lt;span class="nx">Year&lt;/span> &lt;span class="p">&amp;gt;&lt;/span> &lt;span class="mi">1000&lt;/span> &lt;span class="o">||&lt;/span> &lt;span class="p">(&lt;/span>&lt;span class="nx">dday&lt;/span>&lt;span class="p">.&lt;/span>&lt;span class="nx">Year&lt;/span>&lt;span class="o">-&lt;/span>&lt;span class="nx">today&lt;/span>&lt;span class="p">.&lt;/span>&lt;span class="nx">Year&lt;/span> &lt;span class="o">==&lt;/span> &lt;span class="mi">1000&lt;/span> &lt;span class="o">&amp;amp;&amp;amp;&lt;/span> &lt;span class="p">(&lt;/span>&lt;span class="nx">dday&lt;/span>&lt;span class="p">.&lt;/span>&lt;span class="nx">Month&lt;/span> &lt;span class="p">&amp;gt;&lt;/span> &lt;span class="nx">today&lt;/span>&lt;span class="p">.&lt;/span>&lt;span class="nx">Month&lt;/span> &lt;span class="o">||&lt;/span> &lt;span class="p">(&lt;/span>&lt;span class="nx">dday&lt;/span>&lt;span class="p">.&lt;/span>&lt;span class="nx">Month&lt;/span> &lt;span class="o">==&lt;/span> &lt;span class="nx">today&lt;/span>&lt;span class="p">.&lt;/span>&lt;span class="nx">Month&lt;/span> &lt;span class="o">&amp;amp;&amp;amp;&lt;/span> &lt;span class="nx">dday&lt;/span>&lt;span class="p">.&lt;/span>&lt;span class="nx">Day&lt;/span> &lt;span class="o">&amp;gt;=&lt;/span> &lt;span class="nx">today&lt;/span>&lt;span class="p">.&lt;/span>&lt;span class="nx">Day&lt;/span>&lt;span class="p">)))&lt;/span> &lt;span class="p">{&lt;/span>
