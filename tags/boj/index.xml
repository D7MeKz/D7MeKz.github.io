&lt;/span>&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">&lt;span class="c1">&lt;/span> &lt;span class="nx">daysBetweenYears&lt;/span> &lt;span class="o">:=&lt;/span> &lt;span class="mi">0&lt;/span>
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> &lt;span class="k">for&lt;/span> &lt;span class="nx">year&lt;/span> &lt;span class="o">:=&lt;/span> &lt;span class="nx">today&lt;/span>&lt;span class="p">.&lt;/span>&lt;span class="nx">Year&lt;/span>&lt;span class="p">;&lt;/span> &lt;span class="nx">year&lt;/span> &lt;span class="p">&amp;lt;&lt;/span> &lt;span class="nx">dday&lt;/span>&lt;span class="p">.&lt;/span>&lt;span class="nx">Year&lt;/span>&lt;span class="p">;&lt;/span> &lt;span class="nx">year&lt;/span>&lt;span class="o">++&lt;/span> &lt;span class="p">{&lt;/span>
